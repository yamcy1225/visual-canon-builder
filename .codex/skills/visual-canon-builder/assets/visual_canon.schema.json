{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-canon-builder.local/schema/visual_canon.schema.json",
  "title": "Visual Canon",
  "type": "object",
  "properties": {
    "entity_type": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "canon_assertions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/canon_assertion"
      }
    },
    "user_answers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/user_answer"
      }
    },
    "generation_contract": {
      "type": "object"
    },
    "reference_preserve_model": {
      "type": "object"
    },
    "source_cell_asset_manifest": {
      "type": ["object", "array"]
    },
    "exact_text_policy": {
      "type": "object"
    },
    "interview_policy": {
      "$ref": "#/$defs/interview_policy"
    },
    "question_queue": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "proportion_lock_profile": {
      "$ref": "#/$defs/proportion_lock_profile"
    },
    "lock_summary": {
      "type": "object"
    },
    "imagegen_handoff": {
      "type": "object"
    }
  },
  "$defs": {
    "interview_policy": {
      "type": "object",
      "properties": {
        "mode": {
          "enum": [
            "quick",
            "standard",
            "deep_canon",
            "audit"
          ]
        },
        "max_active_questions_per_turn": {
          "type": "integer",
          "minimum": 1
        },
        "max_total_questions": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "enum": [
                "unbounded",
                "until_resolved"
              ]
            }
          ]
        },
        "minimum_passes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stop_condition": {
          "type": "string"
        }
      }
    },
    "proportion_lock_profile": {
      "type": "object",
      "properties": {
        "mode": {
          "enum": [
            "numeric_ratio_lock",
            "descriptive_only"
          ]
        },
        "source_cell_id": {
          "type": "string"
        },
        "unit_basis": {
          "type": "string"
        },
        "ratio_locks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ratio_lock"
          }
        }
      }
    },
    "ratio_lock": {
      "type": "object",
      "required": [
        "id",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "numerator_landmark": {
          "type": "string"
        },
        "denominator_landmark": {
          "type": "string"
        },
        "target": {
          "type": "number"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "prompt_phrase": {
          "type": "string"
        },
        "reject_if": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "canon_assertion": {
      "type": "object",
      "required": [
        "id",
        "subject",
        "predicate",
        "object",
        "evidence_refs",
        "retrieval_scope",
        "confidence",
        "canon_status",
        "approval_status"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "predicate": {
          "type": "string"
        },
        "object": {},
        "assertion_version": {
          "type": "integer",
          "minimum": 1
        },
        "value_hash": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "retrieval_scope": {
          "type": "string"
        },
        "confidence": {
          "enum": [
            "observed",
            "inferred",
            "low_confidence",
            "needs_confirmation",
            "user_confirmed",
            "rejected"
          ]
        },
        "canon_status": {
          "enum": [
            "confirmed",
            "provisional",
            "unresolved",
            "rejected"
          ]
        },
        "approval_status": {
          "enum": [
            "pending_user_approval",
            "approved",
            "rejected",
            "revised",
            "keep_provisional"
          ]
        },
        "derived_from": {
          "type": ["array", "string"]
        },
        "needs_confirmation": {
          "type": "boolean"
        }
      }
    },
    "user_answer": {
      "type": "object",
      "required": [
        "id",
        "asserted_by",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "answers_question": {
          "type": "string"
        },
        "applies_to_assertion": {
          "type": "string"
        },
        "applies_to": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "asserted_by": {
          "type": "string"
        },
        "confidence": {
          "const": "user_confirmed"
        }
      }
    }
  }
}
