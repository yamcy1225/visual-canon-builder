{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-canon-builder.local/schema/visual_canon.schema.json",
  "title": "Visual Canon",
  "type": "object",
  "properties": {
    "entity_type": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "canon_assertions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/canon_assertion"
      }
    },
    "user_answers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/user_answer"
      }
    },
    "generation_contract": {
      "type": "object"
    },
    "reference_preserve_model": {
      "type": "object"
    },
    "source_cell_asset_manifest": {
      "type": ["object", "array"]
    },
    "exact_text_policy": {
      "type": "object"
    },
    "imagegen_handoff": {
      "type": "object"
    }
  },
  "$defs": {
    "canon_assertion": {
      "type": "object",
      "required": [
        "id",
        "subject",
        "predicate",
        "object",
        "evidence_refs",
        "retrieval_scope",
        "confidence",
        "canon_status",
        "approval_status"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "predicate": {
          "type": "string"
        },
        "object": {},
        "assertion_version": {
          "type": "integer",
          "minimum": 1
        },
        "value_hash": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "retrieval_scope": {
          "type": "string"
        },
        "confidence": {
          "enum": [
            "observed",
            "inferred",
            "low_confidence",
            "needs_confirmation",
            "user_confirmed",
            "rejected"
          ]
        },
        "canon_status": {
          "enum": [
            "confirmed",
            "provisional",
            "unresolved",
            "rejected"
          ]
        },
        "approval_status": {
          "enum": [
            "pending_user_approval",
            "approved",
            "rejected",
            "revised",
            "keep_provisional"
          ]
        },
        "derived_from": {
          "type": ["array", "string"]
        },
        "needs_confirmation": {
          "type": "boolean"
        }
      }
    },
    "user_answer": {
      "type": "object",
      "required": [
        "id",
        "asserted_by",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "answers_question": {
          "type": "string"
        },
        "applies_to_assertion": {
          "type": "string"
        },
        "applies_to": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "asserted_by": {
          "type": "string"
        },
        "confidence": {
          "const": "user_confirmed"
        }
      }
    }
  }
}
