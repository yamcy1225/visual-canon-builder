{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visual-canon-builder.local/schema/prompt_pack.schema.json",
  "title": "Imagegen Prompt Pack",
  "type": "object",
  "required": [
    "prompt_pack"
  ],
  "properties": {
    "prompt_pack": {
      "type": "object",
      "required": [
        "handoff_status",
        "api_execution_profile",
        "technical_contract",
        "final_imagegen_prompt",
        "confirmed_constraints",
        "provisional_constraints",
        "evaluation_checklist"
      ],
      "properties": {
        "handoff_status": {
          "enum": [
            "ready",
            "provisional",
            "blocked"
          ]
        },
        "api_execution_profile": {
          "type": "object",
          "required": [
            "preferred_api",
            "model_family",
            "action",
            "input_fidelity",
            "reference_ordering"
          ],
          "properties": {
            "preferred_api": {
              "enum": [
                "responses_api",
                "image_api"
              ]
            },
            "model_family": {
              "const": "gpt_image"
            },
            "action": {
              "enum": [
                "auto",
                "generate",
                "edit"
              ]
            },
            "input_fidelity": {
              "enum": [
                "high",
                "low"
              ]
            },
            "reference_ordering": {
              "type": "object"
            },
            "mask": {
              "type": "object"
            },
            "output": {
              "type": "object"
            }
          }
        },
        "source_cell_asset": {
          "type": "object"
        },
        "technical_contract": {
          "type": "object"
        },
        "final_imagegen_prompt": {
          "type": "string",
          "minLength": 80,
          "maxLength": 3000
        },
        "confirmed_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provisional_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unresolved_questions": {
          "type": "array"
        },
        "avoid": {
          "type": "array"
        },
        "evaluation_checklist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
